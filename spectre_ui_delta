-- Function to create a menu section
local function createMenuSection(parent, sectionName, items)
	local sectionFrame = Instance.new("Frame")
	sectionFrame.Name = sectionName .. "Section"
	sectionFrame.Size = UDim2.new(1, 0, 0, 0)
	sectionFrame.BackgroundColor3 = COLORS.Background
	sectionFrame.BorderSizePixel = 0
	sectionFrame.Parent = parent
	
	-- Section header
	local headerLabel = Instance.new("TextLabel")
	headerLabel.Name = "SectionHeader"
	headerLabel.Size = UDim2.new(1, 0, 0, 30)
	headerLabel.BackgroundColor3 = COLORS.Header
	headerLabel.BorderSizePixel = 0
	headerLabel.Text = "▶ " .. sectionName
	headerLabel.TextColor3 = COLORS.Cyan
	headerLabel.TextSize = 14
	headerLabel.Font = Enum.Font.GothamBold
	headerLabel.TextXAlignment = Enum.TextXAlignment.Left
	headerLabel.Parent = sectionFrame
	
	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, 10)
	padding.Parent = headerLabel
	
	local itemsFrame = Instance.new("Frame")
	itemsFrame.Name = "ItemsFrame"
	itemsFrame.Size = UDim2.new(1, 0, 0, 0)
	itemsFrame.Position = UDim2.new(0, 0, 0, 30)
	itemsFrame.BackgroundColor3 = COLORS.Background
	itemsFrame.BorderSizePixel = 0
	itemsFrame.Parent = sectionFrame
	
	local itemLayout = Instance.new("UIListLayout")
	itemLayout.Parent = itemsFrame
	itemLayout.Padding = UDim.new(0, 0)
	
	local yOffset = 30
	
	for itemName, defaultValue in pairs(items) do
		local itemFrame = Instance.new("Frame")
		itemFrame.Name = itemName .. "Item"
		itemFrame.Size = UDim2.new(1, 0, 0, 30)
		itemFrame.BackgroundColor3 = COLORS.Background
		itemFrame.BorderSizePixel = 1
		itemFrame.BorderColor3 = COLORS.Border
		itemFrame.Parent = itemsFrame
		
		-- Item label
		local itemLabel = Instance.new("TextLabel")
		itemLabel.Name = "Label"
		itemLabel.Size = UDim2.new(0.6, 0, 1, 0)
		itemLabel.BackgroundColor3 = COLORS.Background
		itemLabel.BorderSizePixel = 0
		itemLabel.Text = itemName
		itemLabel.TextColor3 = COLORS.Text
		itemLabel.TextSize = 12
		itemLabel.Font = Enum.Font.Gotham
		itemLabel.TextXAlignment = Enum.TextXAlignment.Left
		itemLabel.Parent = itemFrame
		
		local labelPadding = Instance.new("UIPadding")
		labelPadding.PaddingLeft = UDim.new(0, 10)
		labelPadding.Parent = itemLabel
		
		-- Control (toggle, slider, or text)
		if typeof(defaultValue) == "boolean" then
			-- Toggle checkbox
			local toggleButton = Instance.new("TextButton")
			toggleButton.Name = "Toggle"
			toggleButton.Size = UDim2.new(0, 20, 0, 20)
			toggleButton.Position = UDim2.new(0.85, 0, 0.5, -10)
			toggleButton.BackgroundColor3 = defaultValue and COLORS.Cyan or COLORS.Panel
			toggleButton.BorderSizePixel = 1
			toggleButton.BorderColor3 = COLORS.Cyan
			toggleButton.Text = defaultValue and "✓" or ""
			toggleButton.TextColor3 = COLORS.Text
			toggleButton.TextSize = 14
			toggleButton.Font = Enum.Font.GothamBold
			toggleButton.Parent = itemFrame
			
			local toggleCorner = Instance.new("UICorner")
			toggleCorner.CornerRadius = UDim.new(0, 3)
			toggleCorner.Parent = toggleButton
			
			toggleButton.MouseButton1Click:Connect(function()
				menuState[sectionName][itemName] = not menuState[sectionName][itemName]
				toggleButton.BackgroundColor3 = menuState[sectionName][itemName] and COLORS.Cyan or COLORS.Panel
				toggleButton.Text = menuState[sectionName][itemName] and "✓" or ""
			end)
		elseif typeof(defaultValue) == "number" then
			-- Slider
			local sliderFrame = Instance.new("Frame")
			sliderFrame.Name = "SliderFrame"
			sliderFrame.Size = UDim2.new(0.35, 0, 0.6, 0)
			sliderFrame.Position = UDim2.new(0.6, 0, 0.2, 0)
			sliderFrame.BackgroundColor3 = COLORS.Panel
			sliderFrame.BorderSizePixel = 1
			sliderFrame.BorderColor3 = COLORS.Border
			sliderFrame.Parent = itemFrame
			
			local sliderCorner = Instance.new("UICorner")
			sliderCorner.CornerRadius = UDim.new(0, 3)
			sliderCorner.Parent = sliderFrame
			
			local sliderBar = Instance.new("Frame")
			sliderBar.Name = "Bar"
			sliderBar.Size = UDim2.new(defaultValue / 100, 0, 1, 0)
			sliderBar.BackgroundColor3 = COLORS.Cyan
			sliderBar.BorderSizePixel = 0
			sliderBar.Parent = sliderFrame
			
			local barCorner = Instance.new("UICorner")
			barCorner.CornerRadius = UDim.new(0, 3)
			barCorner.Parent = sliderBar
			
			local valueLabel = Instance.new("TextLabel")
			valueLabel.Name = "Value"
			valueLabel.Size = UDim2.new(0, 30, 1, 0)
			valueLabel.Position = UDim2.new(1, 5, 0, 0)
			valueLabel.BackgroundColor3 = COLORS.Background
			valueLabel.BorderSizePixel = 0
			valueLabel.Text = tostring(math.floor(defaultValue))
			valueLabel.TextColor3 = COLORS.TextSecondary
			valueLabel.TextSize = 10
			valueLabel.Font = Enum.Font.Gotham
			valueLabel.Parent = itemFrame
			
			sliderFrame.InputBegan:Connect(function(input, gameProcessed)
				if gameProcessed then return end
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					local connection
					connection = RunService.RenderStepped:Connect(function()
						if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
							local mouse = player:GetMouse()
							local relativeX = math.max(0, math.min(1, (mouse.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X))
							sliderBar.Size = UDim2.new(relativeX, 0, 1, 0)
							menuState[sectionName][itemName] = relativeX * 100
							valueLabel.Text = tostring(math.floor(relativeX * 100))
						else
							connection:Disconnect()
						end
					end)
				end
			end)
		elseif typeof(defaultValue) == "string" then
			-- Text input
			local textBox = Instance.new("TextBox")
			textBox.Name = "TextInput"
			textBox.Size = UDim2.new(0.35, 0, 0.6, 0)
			textBox.Position = UDim2.new(0.6, 0, 0.2, 0)
			textBox.BackgroundColor3 = COLORS.Panel
			textBox.BorderSizePixel = 1
			textBox.BorderColor3 = COLORS.Border
			textBox.Text = defaultValue
			textBox.TextColor3 = COLORS.Text
			textBox.TextSize = 10
			textBox.Font = Enum.Font.Gotham
			textBox.Parent = itemFrame
			
			local textCorner = Instance.new("UICorner")
			textCorner.CornerRadius = UDim.new(0, 3)
			textCorner.Parent = textBox
			
			textBox.FocusLost:Connect(function()
				menuState[sectionName][itemName] = textBox.Text
			end)
		end
		
		yOffset = yOffset + 30
	end
	
	sectionFrame.Size = UDim2.new(1, 0, 0, yOffset)
	
	return sectionFrame
end

-- Populate left column (Aim Assist)
local aimAssistSection = createMenuSection(leftColumn, "Aim Assist", menuState["Aim Assist"])

-- Populate right column (Combat & Recoil)
local combatSection = createMenuSection(rightColumn, "Combat", menuState["Combat"])
local recoilSection = createMenuSection(rightColumn, "Recoil Control", menuState["Recoil Control"])

-- Update canvas sizes
leftColumn.CanvasSize = UDim2.new(0, 0, 0, aimAssistSection.Size.Y.Offset)
rightColumn.CanvasSize = UDim2.new(0, 0, 0, combatSection.Size.Y.Offset + recoilSection.Size.Y.Offset)

-- ==================== INTERACTIONS ====================

-- Floating button click to toggle menu
floatingButton.InputBegan:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		MENU_VISIBLE = not MENU_VISIBLE
		mainFrame.Visible = MENU_VISIBLE
		
		-- Animate button click
		floatingButton:TweenSize(UDim2.new(0, 110, 0, 110), "Out", "Quad", 0.1, true, function()
			floatingButton:TweenSize(UDim2.new(0, 120, 0, 120), "Out", "Quad", 0.1, true)
		end)
	end
end)

-- Toggle menu visibility with M key
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == TOGGLE_KEY then
		MENU_VISIBLE = not MENU_VISIBLE
		mainFrame.Visible = MENU_VISIBLE
	end
end)

-- Make menu draggable
local dragging = false
local dragStart = nil
local frameStart = nil

headerFrame.InputBegan:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = game:GetService("UserInputService"):GetMouseLocation()
		frameStart = mainFrame.Position
	end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

RunService.RenderStepped:Connect(function()
	if dragging and dragStart then
		local mouse = player:GetMouse()
		local delta = mouse.X - dragStart.X
		local deltaY = mouse.Y - dragStart.Y
		mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta, frameStart.Y.Scale, frameStart.Y.Offset + deltaY)
	end
end)

print("✓ SpectreUI loaded successfully! Click the floating button or press M to toggle.")
